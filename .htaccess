# ============================================================
# Siddh Sai Corporation — .htaccess
# Hostinger shared hosting (Apache)
# ============================================================

<IfModule mod_rewrite.c>
RewriteEngine On

# 1. Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2. Force non-www
RewriteCond %{HTTP_HOST} ^www\.siddhsaicorporation\.in [NC]
RewriteRule ^(.*)$ https://siddhsaicorporation.in/$1 [L,R=301]

# 3. Serve existing files and folders directly — no rewrites
# This ensures images, CSS, JS, PHP are never intercepted
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 4. Remove .html from URL — redirect /page.html to /page
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 5. Redirect homepage /index to /
RewriteRule ^index/?$ / [R=301,L]

# 6. Serve .html file for clean URLs (/about serves about.html)
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^([^.]+)/?$ $1.html [L]

# 7. Old WordPress URL redirects
RewriteRule ^services/?$                                                                        /services.html [L,R=301]
RewriteRule ^about-us/?$                                                                        /about.html [L,R=301]
RewriteRule ^faq/?$                                                                             /waterproofing-landing.html [L,R=301]
RewriteRule ^blog/?$                                                                            /services.html [L,R=301]
RewriteRule ^waterproofing-services-in-surat/?$                                                 /waterproofing-landing.html [L,R=301]
RewriteRule ^expert-reconstruction-services-in-surat/?$                                         /reconstruction-services.html [L,R=301]
RewriteRule ^electrical-services/?$                                                             /electrical-services.html [L,R=301]
RewriteRule ^professional-plumbing-services-in-surat/?$                                         /plumbing-services.html [L,R=301]
RewriteRule ^professional-plastering-services-in-surat/?$                                       /plastering-services.html [L,R=301]
RewriteRule ^roofing-services-in-surat/?$                                                       /roofing-services.html [L,R=301]
RewriteRule ^flooring-services-in-surat/?$                                                      /flooring-services.html [L,R=301]
RewriteRule ^fall-ceiling-services-in-surat/?$                                                  /false-ceiling-services.html [L,R=301]
RewriteRule ^crack-filling-services-in-surat/?$                                                 /structural-crack-filling.html [L,R=301]
RewriteRule ^top-quality-painting-services-in-surat/?$                                          /painting-services.html [L,R=301]
RewriteRule ^siddh-sai-corporation-your-one-stop-shop-for-paver-block-solutions-in-surat/?$     /paver-block-installation.html [L,R=301]
RewriteRule ^leading-installer-of-ground-mounted-solar-panels-in-surat-is-siddh-sai-corporation/?$ /solar-panel-installation.html [L,R=301]
RewriteRule ^comprehensive-guide-to-bitumen-road/?$                                             /bitumen-road-construction.html [L,R=301]
RewriteRule ^siddh-sai-corporation-comprehensive-rcc-road-construction-services-in-surat/?$    /rcc-road-construction.html [L,R=301]
RewriteRule ^leading-construction-companies-in-surat/?$                                         /commercial-space-renovation.html [L,R=301]

# 8. Block old WordPress system paths
RewriteRule ^wp-admin(.*)$   /index.html [L,R=301]
RewriteRule ^wp-includes(.*)$ /index.html [L,R=301]
RewriteRule ^wp-login\.php$  /index.html [L,R=301]
RewriteRule ^xmlrpc\.php$    /index.html [L,R=301]
RewriteRule ^feed/?$         /index.html [L,R=301]

</IfModule>

# Custom error page
ErrorDocument 404 /index.html

# Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json image/svg+xml
</IfModule>

# Browser caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# Disable directory browsing
Options -Indexes

# Protect .htaccess
<Files ".htaccess">
  Order Allow,Deny
  Deny from all
</Files>
